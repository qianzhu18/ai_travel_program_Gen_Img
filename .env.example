# ============================================
# AI图片批量生成系统 - 环境配置
# 复制此文件为 .env 并填入实际值
# ============================================

# --- 应用配置 ---
APP_NAME="AI图片批量生成系统"
APP_VERSION="1.0.0"
DEBUG=false

# --- 服务器配置 ---
HOST=0.0.0.0
PORT=8000

# --- 数据库 ---
# 本地运行：sqlite:///./data/database.db
# Docker 运行：sqlite:////app/data/database.db
DATABASE_URL=sqlite:///./data/database.db

# --- AI 服务 API 密钥 ---
# API易平台（SeedDream 4.5 + Nano Banana Pro）
APIYI_API_KEY=your_apiyi_key_here
APIYI_API_URL=https://api.apiyi.com

# 阿里百炼（提示词生成）
BAILIAN_API_KEY=your_bailian_key_here
BAILIAN_API_URL=https://dashscope.aliyuncs.com/api/v1

# --- 引擎选择 ---
# 生图引擎 (seedream / nanobanana)
IMAGE_GENERATION_ENGINE=seedream
# 宽脸图引擎 (seedream / nanobanana)
WIDEFACE_GENERATION_ENGINE=nanobanana

# --- IOPaint 服务 ---
# 本地运行：http://localhost:8090
# Docker 运行：http://iopaint:8090
IOPAINT_URL=http://localhost:8090

# --- Volcengine 视觉服务（去水印）---
VOLC_ACCESS_KEY_ID=your_volc_access_key_id_here
VOLC_SECRET_ACCESS_KEY=your_volc_secret_access_key_here
VOLC_REGION=cn-north-1
VOLC_SERVICE=cv

# --- 导出目录 ---
# 本地运行：~/Pictures/AI图片导出
# Docker 运行：/app/data/exports
DEFAULT_EXPORT_DIR=~/Pictures/AI图片导出

# ============================================
# Docker 部署说明
# ============================================
# 1. 复制此文件为 .env：cp .env.example .env
# 2. 填入 API 密钥
# 3. 启动：docker compose up -d
# 4. 访问：http://localhost:3000
# 5. 数据持久化在 ./data 目录
# 6. 模型文件放在 ./models 目录（只读挂载）
